manifest {
    name            = 'nf-rnator'
    description     = 'Minimal BRB-seq pipeline: FastQC + multi-genome STARsolo + project/plate h5ad splitting + QC reports'
    author          = 'Claire Regan'
    homePage        = 'https://github.com/cregan727/nf-rnator'
    mainScript      = 'main.nf'
    nextflowVersion = '>=22.10.0'  // conservative estimate, not rigorously tested against older
                                     // versions -- this pipeline uses only standard DSL2 features
                                     // (no nf-schema/nf-validation plugin, nothing version-specific)
    version         = '0.1.0'
}

process {
    executor = 'local'   // run everything inside whatever SLURM allocation submits this job -- no sub-job submission

    withName: 'STARSOLO' {
        container = 'quay.io/biocontainers/star:2.7.10b--h9ee0642_0'
    }
    withName: 'FASTQC' {
        container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
    }
    withName: 'MTX_TO_H5AD|MERGE_PLATE_GENOMES|SPLIT_H5AD_BY_PROJECT|MERGE_PROJECT_H5AD|PLATE_REPORT|PROJECT_REPORT|EXPORT_GENE_TABLE' {
        // quay.io/biocontainers/scanpy does NOT have this or any recent tag --
        // verified directly: bioconda's scanpy package tops out at 1.7.2
        // (April 2021), so biocontainers never built a container for 1.9.x+.
        // Using a Seqera Wave-built image instead (built from conda-forge,
        // not limited to bioconda's stale package) -- this exact container
        // was already confirmed working in this environment earlier this
        // session (nf-core/scrnaseq's own MTX_TO_H5AD step used it
        // successfully after the pullTimeout fix), not a fresh guess.
        container = 'community.wave.seqera.io/library/scanpy:1.10.2--e83da2205b92a538'
    }
}

// Container engine varies by cluster -- select with -profile <name>.
// Many clusters have migrated from Singularity to Apptainer (a fork/rebrand,
// same commands, different Nextflow config scope needed) -- check
// `module avail singularity apptainer docker` before assuming.
profiles {
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        singularity.pullTimeout = '60 min'
        // adjust to wherever you want pulled images cached, e.g.:
        // singularity.cacheDir = "${launchDir}/singularity_cache"
    }
    apptainer {
        apptainer.enabled     = true
        apptainer.autoMounts  = true
        apptainer.pullTimeout = '60 min'
    }
    docker {
        docker.enabled = true
    }
}
